{
  "name": "myhorrorstory",
  "version": "0.1.0",
  "private": true,
  "description": "Commercial-grade cross-platform horror mystery platform monorepo.",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm -r --parallel dev",
    "dev:openclaw": "powershell -ExecutionPolicy Bypass -File scripts/start-openclaw-local.ps1",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "test:api:integration": "corepack pnpm --filter @myhorrorstory/api test:integration",
    "test:e2e:install": "corepack pnpm exec playwright install chromium",
    "test:e2e": "corepack pnpm exec playwright test --config tests/e2e/playwright.config.ts",
    "test:commercial": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:api:integration && corepack pnpm test:e2e",
    "typecheck": "corepack pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "remote:test:start": "node scripts/remote-test/start.mjs",
    "remote:test:stop": "node scripts/remote-test/stop.mjs",
    "remote:test:status": "node scripts/remote-test/status.mjs",
    "messaging:setup": "node scripts/messaging/setup.mjs",
    "messaging:connect": "node scripts/messaging/connect.mjs",
    "messaging:connect:owner": "node scripts/messaging/connect.mjs --import-myaika --phone 8127810028 --case-id static-between-stations --player-id owner-local",
    "linear:bots:plan": "node scripts/linear-bots/control.mjs --dry-run",
    "linear:bots:apply": "node scripts/linear-bots/control.mjs --apply",
    "linear:bots:autorun": "node scripts/linear-bots/autorun.mjs",
    "linear:bots:autorun:once": "node scripts/linear-bots/autorun.mjs --once",
    "linear:bots:autorun:dry": "node scripts/linear-bots/autorun.mjs --once --dry-run",
    "linear:bots:dispatch-package": "node scripts/linear-bots/dispatch-production-package.mjs --apply",
    "linear:bots:dispatch-package:dry": "node scripts/linear-bots/dispatch-production-package.mjs",
    "linear:bots:dispatch-agent-army": "node scripts/linear-bots/dispatch-production-package.mjs --apply --backlog docs/operations/linear-agent-army-backlog.json",
    "linear:bots:dispatch-agent-army:dry": "node scripts/linear-bots/dispatch-production-package.mjs --backlog docs/operations/linear-agent-army-backlog.json",
    "linear:bots:dispatch-real-assets": "node scripts/linear-bots/dispatch-production-package.mjs --apply --backlog docs/operations/linear-real-asset-backlog.json",
    "linear:bots:dispatch-real-assets:dry": "node scripts/linear-bots/dispatch-production-package.mjs --backlog docs/operations/linear-real-asset-backlog.json",
    "linear:oauth:connect": "node scripts/linear-bots/connect-page.mjs --open",
    "linear:oauth:url": "node scripts/linear-bots/oauth.mjs authorize-url",
    "linear:oauth:exchange": "node scripts/linear-bots/oauth.mjs exchange-code --pretty",
    "linear:oauth:refresh": "node scripts/linear-bots/oauth.mjs refresh-token --pretty",
    "linear:oauth:client-credentials": "node scripts/linear-bots/oauth.mjs client-credentials --pretty",
    "creative:build-plan": "node scripts/creative/build-commercial-experience-plan.mjs",
    "creative:build-agent-army": "node scripts/creative/build-agent-army-plan.mjs",
    "creative:build-real-asset-ops": "node scripts/creative/build-real-asset-ops.mjs",
    "creative:materialize-agent-army": "node scripts/creative/materialize-agent-army-assets.mjs",
    "creative:regenerate-commercial-images": "node scripts/creative/regenerate-commercial-image-failures.mjs",
    "creative:qa-image-text": "node scripts/creative/qc-agent-army-images.mjs",
    "creative:verify-agent-army": "node scripts/creative/verify-agent-army-assets.mjs",
    "creative:test-real-assets": "node scripts/creative/test-real-asset-generation.mjs",
    "creative:dispatch-openclaw-agent-army": "node scripts/creative/dispatch-openclaw-agent-army.mjs --execute",
    "creative:dispatch-openclaw-agent-army:dry": "node scripts/creative/dispatch-openclaw-agent-army.mjs",
    "creative:dispatch-openclaw-agent-army:arg": "node scripts/creative/dispatch-openclaw-agent-army.mjs --jobs docs/operations/openclaw-arg-reframe-jobs.json --execute",
    "creative:dispatch-openclaw-agent-army:arg:dry": "node scripts/creative/dispatch-openclaw-agent-army.mjs --jobs docs/operations/openclaw-arg-reframe-jobs.json",
    "creative:dispatch-openclaw-real-assets": "node scripts/creative/dispatch-openclaw-agent-army.mjs --jobs docs/operations/openclaw-real-asset-jobs.json --execute --allow-unstructured",
    "creative:dispatch-openclaw-real-assets:dry": "node scripts/creative/dispatch-openclaw-agent-army.mjs --jobs docs/operations/openclaw-real-asset-jobs.json",
    "creative:generate-visuals": "node scripts/creative/generate-visual-assets.mjs",
    "creative:generate-free-ai-assets": "node scripts/creative/generate-free-ai-assets.mjs",
    "creative:materialize-assets": "node scripts/creative/materialize-commercial-assets.mjs",
    "creative:validate-visuals": "node scripts/creative/validate-visual-assets.mjs",
    "simulations:build-playthrough": "node scripts/creative/build-playthrough-simulations.mjs",
    "stories:refine-director-cut": "node scripts/creative/refine-drama-director-cut.mjs",
    "qa:simulate-stories": "node scripts/qa/run-quality-agent-simulations.mjs",
    "stories:generate": "node scripts/generate-story-packages.mjs",
    "stories:build-dossiers": "node scripts/creative/build-character-dossiers.mjs",
    "stories:build-compendium": "node scripts/creative/build-story-branching-compendium.mjs",
    "stories:build-arg": "node scripts/creative/build-arg-campaigns.mjs",
    "stories:build-drama": "node scripts/creative/build-arg-campaigns.mjs",
    "stories:build-drama:legacy": "node scripts/creative/build-drama-packages.mjs",
    "voice:build-drama": "node scripts/creative/build-voice-drama-packages.mjs",
    "db:generate": "corepack pnpm --filter @myhorrorstory/db db:generate",
    "db:migrate": "corepack pnpm --filter @myhorrorstory/db db:migrate",
    "db:seed": "corepack pnpm --filter @myhorrorstory/db db:seed",
    "validate": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "ffmpeg-static": "^5.3.0",
    "prettier": "^3.5.2",
    "tesseract.js": "^7.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.7"
  }
}

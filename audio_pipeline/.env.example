# Copy this file to audio_pipeline/.env and fill in your own credentials.
# Do not commit real keys.

# Mubert API credentials (required for adaptive integration in game runtime).
MUBERT_CUSTOMER_ID=replace_with_customer_id
MUBERT_ACCESS_TOKEN=replace_with_access_token

# Optional: explicit model cache path for Hugging Face / AudioCraft models.
HF_HOME=

# Optional: force CPU if your GPU setup is unstable for local generation.
# AUDIO_PIPELINE_DEVICE=cpu
